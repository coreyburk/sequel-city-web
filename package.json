{
  "name": "sequel-city-web",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build --workspace apps/api",
    "dev": "concurrently -n api,web \"npm run dev --workspace apps/api\" \"npm run dev --workspace apps/web\"",
    "start": "npm run start --workspace apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
